{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "rules.md",
    "markdown-style.md"
  ],
  "plugin": [  ],
  "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 20000
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "microsoft/playwright-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "com.figma.mcp/mcp": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
    },
    "com.stackoverflow.mcp/mcp": {
      "type": "remote",
      "url": "https://mcp.stackoverflow.com",
    }
  }
}
