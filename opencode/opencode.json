{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["rules.md"],
  "plugin": ["@franlol/opencode-md-table-formatter@latest"],
  "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 20000
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
  "permission": {
    "bash": {
      "git commit*": "ask",
      "git push*": "ask"
    }
  },
  "formatter": {
    "prettier-markdown": {
      "command": ["npx", "-y", "prettier", "--write", "$FILE"],
      "extensions": [".md", ".mdx"],
      "environment": {
        "NODE_ENV": "production"
      }
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "microsoft/playwright-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "com.stackoverflow.mcp/mcp": {
      "type": "remote",
      "url": "https://mcp.stackoverflow.com"
    }
  }
}
