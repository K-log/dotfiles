{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["rules.md"],
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.6"
  ],
  "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 20000
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
  "permission": {
    "bash": {
      "*": "deny",
      "git *": "ask",
      "git commit *": "deny",
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "*": "deny",
          "git *": "ask",
          "git commit *": "deny",
        }
      }
    },
    "build": {
      "permission": {
        "bash": {
          "*": "deny",
          "git *": "ask",
          "git commit *": "deny",
        }
      }
    }
  },
  "formatter": {
    "prettier-markdown": {
      "command": ["npx", "-y", "prettier", "--write", "$FILE"],
      "extensions": [".md", ".mdx"],
      "environment": {
        "NODE_ENV": "production"
      }
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "microsoft/playwright-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    }
  }
}
